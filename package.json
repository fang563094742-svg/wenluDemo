{
  "name": "wenlu",
  "version": "0.1.0",
  "private": true,
  "description": "问路（Wenlu）：把复杂目标梳成清晰判断、明确动作和可执行下一步的最小判断与执行入口",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "demo": "tsx scripts/demoScheduler.ts",
    "demo:parallel": "tsx scripts/demoScheduler.ts --scenario=parallel",
    "demo:conflict": "tsx scripts/demoScheduler.ts --scenario=conflict",
    "demo:budget": "tsx scripts/demoScheduler.ts --scenario=budget",
    "demo:cache": "tsx scripts/demoScheduler.ts --scenario=cache",
    "demo:pipeline": "tsx scripts/demoFullPipeline.ts",
    "demo:pipeline:fail": "tsx scripts/demoFullPipeline.ts --fail",
    "river": "npx tsx src/riverMain.ts",
    "river:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-river-windows.ps1",
    "river:build": "tsc && node dist/src/riverMain.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build:binary": "tsx scripts/buildBinary.ts",
    "deal:triage": "tsx scripts/dealAccelerator.ts",
    "capability:report": "tsx scripts/capabilityReport.ts",
    "copy:compress": "tsx scripts/copyCompressor.ts",
    "card:final": "tsx scripts/finalExecutionCard.ts",
    "api": "tsx src/api/start.ts",
    "api:dev": "tsx watch src/api/start.ts",
    "learning:line": "tsx scripts/learningLine.ts",
    "cognitive:upgrade": "tsx data/output/cognitiveUpgradeLaw.ts",
    "response:strategy": "tsx scripts/responseStrategyLine.ts",
    "tool:dominance": "tsx data/output/toolDominanceLine.ts",
    "tool:judgment": "tsx scripts/toolJudgmentLaw.ts",
    "tool:surface": "tsx scripts/executorControlSurface.ts",
    "demand:scan": "tsx scripts/publicDemandScanner.ts",
    "capability:frontdesk": "tsx scripts/capabilityFrontdesk.ts",
    "attempt:ledger": "tsx data/output/attemptEvidenceLedger.ts",
    "truth:safari3210": "tsx data/output/safari3210SingleSource.ts",
    "frontdesk:layered": "tsx data/output/publicLayeredFrontdesk.ts",
    "single:lead:card": "tsx data/output/singleLeadCard.ts",
    "truth:safari3210:layered": "tsx data/output/safari3210LayeredSingleCard.ts",
    "plan:billion": "tsx scripts/presidentBillionPlan.ts",
    "trace:10m": "tsx data/output/tenMinuteActionTraceLedger.ts",
    "trace:10m:verify": "tsx data/output/tenMinuteActionTraceVerifier.ts",
    "polymarket:probe": "tsx scripts/polymarketTrackerProbe.ts",
    "polymarket:snapshot": "tsx scripts/polymarketSnapshot.ts",
    "polymarket:snapshot:verify": "tsx scripts/polymarketSnapshotVerify.ts",
    "plan:shrink": "tsx scripts/tasklinePlannerCli.ts",
    "admin": "tsx src/admin/start.ts",
    "admin:dev": "tsx watch src/admin/start.ts"
  },
  "dependencies": {
    "chess.js": "^1.4.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "playwright": "^1.60.0",
    "pg": "^8.21.0",
    "socks": "2.8.3",
    "undici": "6.26.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "fast-check": "^3.23.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
