# proactive-awareness-demo 环境变量示例。
# 复制为 .env 并填入真实值；.env 已被 .gitignore 忽略，真实值绝不入库。
# config 读取优先级：优先 OPENAI_API_KEY，次选 GPT_API_KEY（任务 2.1）。

# GPT-5.4 API key（二选一，优先 OPENAI_API_KEY）
OPENAI_API_KEY=your-api-key-here
# GPT_API_KEY=your-api-key-here

# 可选：Web 服务端口（默认见 config）
# PORT=4173

# ─── 大脑去单点：LLM 池（主中转 → 备用中转 → 本地兜底）───
# 备用中转（OpenAI 兼容；主端点挂了自动转这里）
# WENLU_LLM_BACKUP_BASE_URL=https://backup-relay.example/v1
# WENLU_LLM_BACKUP_API_KEY=your-backup-key   # 缺省回退主 key
# WENLU_LLM_BACKUP_MODEL=gpt-5.4
# 本地模型兜底（OpenAI 兼容，如 Ollama；断网/中转全挂时接管呼吸，不主依赖 API）
# WENLU_LOCAL_BASE_URL=http://127.0.0.1:11434/v1
# WENLU_LOCAL_MODEL=qwen2.5
# OpenAI 官方直连·经境外出口（中转全挂时的独立通路；需配出口）
# WENLU_OPENAI_DIRECT_KEY=sk-...
# WENLU_OPENAI_DIRECT_MODEL=gpt-4o

# ─── 统一出网层：境外出口（破 SNI/IP 阻断，打通 DuckDuckGo/Google）───
# 支持 http/https/socks5 代理，或自建境外 fetch-relay。仅对被授权用户启用（订阅 ∩ 河床 D11 判断）。
# WENLU_EGRESS_PROXY=http://127.0.0.1:7890
# WENLU_EGRESS_PROXY=socks5://127.0.0.1:1080

# ─── PostgreSQL（多用户隔离 + 全量存储；multiuser-pg-store）───
# 业务库 wenlu，沿用 postgres 账号；首次启动自动建库（连 WENLU_DB_ADMIN_NAME 库执行 CREATE DATABASE）。
# WENLU_DB_HOST=127.0.0.1
# WENLU_DB_PORT=5432
# WENLU_DB_NAME=wenlu
# WENLU_DB_USER=postgres
# WENLU_DB_PASSWORD=Wenlu@Pg2026
# WENLU_DB_ADMIN_NAME=postgres
# WENLU_DB_MAX_CONN=20
# WENLU_DB_IDLE_TIMEOUT=30000
# WENLU_DB_CONN_TIMEOUT=5000
