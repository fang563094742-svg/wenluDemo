# proactive-awareness-demo 环境变量示例。
# 复制为 .env 并填入真实值；.env 已被 .gitignore 忽略，真实值绝不入库。
# config 读取优先级：优先 OPENAI_API_KEY，次选 GPT_API_KEY（任务 2.1）。

# GPT-5.4 API key（二选一，优先 OPENAI_API_KEY）
OPENAI_API_KEY=your-api-key-here
# GPT_API_KEY=your-api-key-here

# 可选：Web 服务端口（默认见 config）
# PORT=4173

# API 服务
# API_PORT=3721
# API_HOST=0.0.0.0

# PostgreSQL（本地默认可直接配合 docker compose）
# WENLU_DB_HOST=127.0.0.1
# WENLU_DB_PORT=5432
# WENLU_DB_NAME=wenlu
# WENLU_DB_USER=wenlu
# WENLU_DB_PASSWORD=wenlu_dev

# 登录态
# JWT_SECRET=change-me
# JWT_ACCESS_EXPIRES_IN=2592000
# REFRESH_TOKEN_EXPIRES_IN=15552000

# go-captcha（已接入）
# 验证码总开关（开/关）。缺省 true=开；设 false/0/off/no=关（本地开发/Windows 无 captcha 助手时关掉）。
# 现已惰性读取：改这一行 + 重启服务即可生效（无需再用启动 shell 环境变量的旧技巧）。
AUTH_CAPTCHA_ENABLED=true
# AUTH_CAPTCHA_TTL_MS=120000
# AUTH_CAPTCHA_TICKET_TTL_MS=600000
# AUTH_CAPTCHA_VERIFY_PADDING=5

# 密码前端加密
# AUTH_PASSWORD_ENCRYPTION_ENABLED=true

# 免费限制
# FREE_DAILY_MESSAGE_LIMIT=10
# FREE_TRIAL_DAYS=3
# MEMBERSHIP_LIMIT_TIMEZONE=Asia/Shanghai

# 支付 / 自动核单
# LDXP_MERCHANT_USERNAME=jiaxin
# LDXP_MERCHANT_PASSWORD=jiaxin
# LDXP_SHOP_URL=https://pay.ldxp.cn/shop/ZUSJM8BX/6idmbq
# LDXP_SHOP_TITLE=商家0178的小店
# LDXP_GOODS_NAME=会员
# LDXP_GOODS_AMOUNT_CENTS=300
# LDXP_SUPPORT_CONTACT=17865770178
# LDXP_RECOMMENDED_PLAN_ID=member
# LDXP_AUTO_RECONCILE_WINDOW_HOURS=72
# LDXP_QR_EXTRACTION_ENABLED=true
# LDXP_QR_HEADLESS=true
# LDXP_QR_BROWSER_CHANNEL=chromium
# LDXP_QR_TIMEOUT_MS=60000
# LDXP_QR_SETTLE_MS=12000
# PUBLIC_APP_BASE_URL=https://your-domain.example

# 管理后台
# ADMIN_HOST=127.0.0.1
# ADMIN_PORT=3782
# ADMIN_ROOT_PATH=/internal-admin
# ADMIN_BASIC_USER=admin
# ADMIN_BASIC_PASSWORD=change-me

# ─── 大脑去单点：LLM 池（主中转 → 备用中转 → 本地兜底）───
# 备用中转（OpenAI 兼容；主端点挂了自动转这里）
# WENLU_LLM_BACKUP_BASE_URL=https://backup-relay.example/v1
# WENLU_LLM_BACKUP_API_KEY=your-backup-key   # 缺省回退主 key
# WENLU_LLM_BACKUP_MODEL=gpt-5.4
# 本地模型兜底（OpenAI 兼容，如 Ollama；断网/中转全挂时接管呼吸，不主依赖 API）
# WENLU_LOCAL_BASE_URL=http://127.0.0.1:11434/v1
# WENLU_LOCAL_MODEL=qwen2.5
# OpenAI 官方直连·经境外出口（中转全挂时的独立通路；需配出口）
# WENLU_OPENAI_DIRECT_KEY=sk-...
# WENLU_OPENAI_DIRECT_MODEL=gpt-4o

# ─── 统一出网层：境外出口（破 SNI/IP 阻断，打通 DuckDuckGo/Google）───
# 支持 http/https/socks5 代理，或自建境外 fetch-relay。仅对被授权用户启用（订阅 ∩ 河床 D11 判断）。
# WENLU_EGRESS_PROXY=http://127.0.0.1:7890
# WENLU_EGRESS_PROXY=socks5://127.0.0.1:1080

# ─── PostgreSQL（多用户隔离 + 全量存储；multiuser-pg-store）───
# 业务库 wenlu，沿用 postgres 账号；首次启动自动建库（连 WENLU_DB_ADMIN_NAME 库执行 CREATE DATABASE）。
# WENLU_DB_HOST=127.0.0.1
# WENLU_DB_PORT=5432
# WENLU_DB_NAME=wenlu
# WENLU_DB_USER=postgres
# WENLU_DB_PASSWORD=Wenlu@Pg2026
# WENLU_DB_ADMIN_NAME=postgres
# WENLU_DB_MAX_CONN=20
# WENLU_DB_IDLE_TIMEOUT=30000
# WENLU_DB_CONN_TIMEOUT=5000
